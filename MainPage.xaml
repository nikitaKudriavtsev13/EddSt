<?xml version="1.0" encoding="utf-8" ?>
<TabbedPage  xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:local="clr-namespace:EddSt.Page"
             xmlns:android="clr-namespace:Microsoft.Maui.Controls.PlatformConfiguration.AndroidSpecific;assembly=Microsoft.Maui.Controls"
            android:TabbedPage.ToolbarPlacement="Bottom"
             Shell.NavBarIsVisible="False"
             xmlns:viewModels="clr-namespace:EddSt.Page.data"
             
             Title="{Binding EggsForAllTime}"
             x:Class="EddSt.MainPage" >

  

    
    <TabbedPage.BindingContext>
        <viewModels:EggViewModel/>
    </TabbedPage.BindingContext>


    <local:EggPage Shell.NavBarIsVisible="False" />
    <local:StatEgg Shell.NavBarIsVisible="False" />
    <local:Abaut Shell.NavBarIsVisible="False" />
    
</TabbedPage>
