<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="EddSt.Page.Abaut"
             Title="КОНТАКТЫ">
    <Border>
        <VerticalStackLayout>
            <Picker x:Name="languagePicker" Title = "цветовая ралитра" HorizontalOptions="Center"
        SelectedIndexChanged="languagePicker_SelectedIndexChanged" FontSize="Default" TextColor="#FFFFFF">
                <Picker.Items >
                    <x:String >СВЕТЛАЯ</x:String>
                    <x:String>ТЕМНАЯ</x:String>
                    <x:String>АВТО</x:String>
                </Picker.Items>
            </Picker>
            <Label 
            Text="Welcome to .NET MAUI!"
            VerticalOptions="Center" 
            HorizontalOptions="Center" />
    </VerticalStackLayout>
    </Border>
</ContentPage>