<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="EddSt.Page.EggPage"
             xmlns:local="clr-namespace:EddSt.Page"
             Title="EggPage">
    <ContentPage.Resources>
        <ResourceDictionary>
            <local:ConvertHeght x:Key="ConvertHeght1" />
        </ResourceDictionary>
    </ContentPage.Resources>

    <VerticalStackLayout  VerticalOptions="Fill" x:Name="ContentEggPageStackLayout" >
        <Border   x:Name="borderAnother" Padding="0,0,0,5">
            <VerticalStackLayout  >
               <Label HorizontalOptions="Center"  Text="Введите количество снесенных яиц"/>
                <FlexLayout  Wrap="Wrap"   HorizontalOptions="Center" VerticalOptions="Center">
                    <VerticalStackLayout>
                        <Entry   x:Name="EntryEgg" Placeholder="Enter howManyEggs" Text="{Binding HowManyEggs}" 
                                 Keyboard="Numeric"  WidthRequest="150"  />
                    <Stepper  Minimum="1" Maximum="110" Increment="1" 
                             Value="{Binding HowManyEggs}" AutomationProperties.IsInAccessibleTree="False"/>
                    </VerticalStackLayout>
                        
                    <Button Text="OK" Command="{Binding AddCommand}" WidthRequest="100" Margin="0" />
                    
                </FlexLayout>
             </VerticalStackLayout>
        </Border>


        <Border  Margin="5"  >
            <Border.HeightRequest>
                <MultiBinding Converter="{StaticResource ConvertHeght1}">
                    <Binding Source="{x:Reference ContentEggPageStackLayout}" Path="Height"/>
                    <Binding Source="{x:Reference borderAnother}" Path="Height"/>
                </MultiBinding>
            </Border.HeightRequest>
            <CollectionView  
                SelectionMode="Single" ItemsSource="{Binding EggsViewModel}" x:Name="ColVeiw"  >

                     <CollectionView.Header  >
                    <Grid  VerticalOptions="Start" HorizontalOptions="Center"   >
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="128"/>
                            <ColumnDefinition Width="128"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Label HorizontalOptions="Center" Margin="10" Text="ID" Grid.Column="0" />
                        <Label  HorizontalOptions="Center"  Margin="10" Text="СКОЛЬКО СНЕСЛОСЬ" Grid.Column="1"/>
                        <Label HorizontalOptions="Center"  Margin="10" Text=" КОГДА СНЕСЛИСЬ" Grid.Column="2"/>
                        <Button Grid.Column="3" Text="X"  Command="{Binding RemoveCommand}"
                            CommandParameter="{Binding Source={x:Reference Name=ColVeiw}, Path=SelectedItem}"
                                Background="#B24E1F" FontSize="14" WidthRequest="1"  />
                    </Grid>

                </CollectionView.Header>
                <CollectionView.ItemTemplate VerticalOptions="Start" HorizontalOptions="Fill" >
                      <DataTemplate  >
                        <Grid   VerticalOptions="Start" HorizontalOptions="Center"   >
                        <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="140"/>
                                <ColumnDefinition Width="180"/>
                            </Grid.ColumnDefinitions>
                            <Label HorizontalOptions="Center" Margin="10"  Text="{Binding Id}" Grid.Column="0"/>
                            <Label HorizontalOptions="Center" Margin="10"  Text="{Binding HowManyEggs}" Grid.Column="1"/>
                            <Label HorizontalOptions="Center" Margin="10"  Text="{Binding DataAdd}" Grid.Column="2"/>
                        </Grid>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
                
            </CollectionView>
        </Border>
        
    </VerticalStackLayout>
</ContentPage>
